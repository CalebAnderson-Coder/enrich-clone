# ============================================================
# .env.example — Empirika AI Fleet (agency-fleet-runtime)
# Copy to .env (local) or set each var in Render (production).
# All secrets MUST be injected via environment, never committed.
# ============================================================

# ===== SERVER =====
NODE_ENV=development
PORT=4000

# ===== LLM PROVIDERS =====
# Primary model: NVIDIA NIM (LLaMA 3.1 70B)
NVIDIA_API_KEY=nvapi-your_nvidia_key_here
# Fallback model: Google Gemini 2.0 Flash (OpenAI-compatible)
GEMINI_API_KEY=your_gemini_key_here
# Optional: Groq (legacy / experimental paths)
GROQ_API_KEY=gsk_your_groq_api_key

# ===== SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ===== WEB RESEARCH & ENRICHMENT =====
APIFY_API_TOKEN=apify_your_token
BRIGHTDATA_API_TOKEN=your_brightdata_token
FIRECRAWL_API_KEY=fc-your_firecrawl_key
HUNTER_API_KEY=your_hunter_key
SEMRUSH_API_KEY=your_semrush_key

# ===== EMAIL (Resend + SMTP fallback) =====
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=agency@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_app_password
SMTP_FROM_NAME=Empirika

# ===== API AUTH =====
API_SECRET_KEY=generate_a_strong_random_string

# ===== FRONTEND URL (set after first Render deploy) =====
FRONTEND_URL=https://your-render-app.onrender.com

# ===== VITE BUILD VARS (dashboard/) =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_API_SECRET_KEY=your_api_secret_key
SUPABASE_PUSHEABLE_KEY_API=your_publishable_key
# Leave VITE_API_URL empty in production to use relative /api paths
VITE_API_URL=

# ===== LEAD MAGNETS (Sprint 4 — niche landing screenshots) =====
# Supabase Storage bucket where lead_magnet_worker uploads the per-niche
# mockup images. Create it manually in Supabase as a PUBLIC bucket.
SUPABASE_LEAD_MAGNET_BUCKET=lead-magnets

# ===== TENANT (will be replaced by multi-tenant in Phase B) =====
BRAND_ID=your_brand_uuid_here

# ===== GHL (GoHighLevel CRM sync — per-brand, configure in Render) =====
EMPIRIKA_GHL_KEY=pit_your_ghl_api_key
EMPIRIKA_GHL_LOCATION_ID=your_location_id
GHL_PIPELINE_COLD_LEADS_ID=your_pipeline_id
GHL_STAGE_NUEVO_ID=your_stage_id

# ===== RENDER (for programmatic deploys + log reads) =====
RENDER_API_SECRET_KEY=rnd_your_render_api_key_here

# ===== AUTONOMY (Sprint 1) =====
# Master switch. When 'true', the Manager daemon fires UTC 8/12/18/23
# cycles and the outreach dispatcher auto-approves drafts past their
# auto_approve_at deadline. Leave 'false' for manual-only mode.
AUTONOMY_ENABLED=false
# Milliseconds added to NOW() when a new campaign_enriched_data row
# is persisted (2h default). Lower = faster auto-approval.
AUTO_APPROVE_TIMEOUT_MS=7200000
# Guardrails — auto-approval stops when any cap is breached.
MAX_SENDS_PER_HOUR=30
MAX_LEADS_PER_DAY_PER_BRAND=50
# Bounce-rate circuit breaker. Above this ratio over the last 24h,
# the dispatcher stops sending and writes a [MANAGER_BLOCKED] memo.
# Rate is computed from campaign_enriched_data.outreach_status
# (buckets BOUNCED/SEND_FAIL/SMTP_ERROR/DELIVERY_FAILED vs SENT).
# Moves to the dedicated outreach_events table in Sprint 5.
BOUNCE_RATE_CIRCUIT_BREAKER=0.05

# ===== LEARNING LOOP (Sprint 2) =====
# Master switch for granular event logging + learning signals.
# When 'false' (default): silent no-op everywhere — logOutreachEvent
# returns null, Scout uses default GATEs, consolidator skips. Flip to
# 'true' AFTER migrations/014_outreach_events.sql is applied.
LEARNING_ENABLED=false
# Public base URL used to build the open-tracking pixel URL
# ({PIXEL_BASE_URL}/pixel/{leadId}.gif). In prod this is your Render
# public URL. Falls back to FRONTEND_URL / RENDER_EXTERNAL_URL.
PIXEL_BASE_URL=
# HMAC-SHA256 shared secret used to verify POST /webhook/ghl-stage.
# Leave empty to keep the endpoint disabled (responds 204).
GHL_WEBHOOK_SECRET=

# ===== ESTRATEGA (Sprint 3 — agente #10) =====
# Master switch del Estratega. Cuando 'false' (default): el daemon omite
# tanto el light-daily (lun-sáb 23 UTC) como el deep-weekly (domingo 12 UTC),
# y el Manager ignora memoria vieja de propuestas.
ESTRATEGA_ENABLED=false
ESTRATEGA_DAILY_HOUR_UTC=23
ESTRATEGA_WEEKLY_DAY=0
ESTRATEGA_WEEKLY_HOUR_UTC=12

# ===== MULTICHANNEL (Sprint 5 — WhatsApp/Baileys + SMS/Twilio) =====
# Master switch. When 'false' (default) the multichannel dispatcher is
# a no-op and the legacy email-only pipeline runs untouched.
MULTICHANNEL_ENABLED=false

# WhatsApp warmup ramp (daily caps by week since first connection).
WA_WARMUP_WEEK1_CAP=5
WA_WARMUP_WEEK2_CAP=15
WA_WARMUP_WEEK3_CAP=30
WA_WARMUP_WEEK4PLUS_CAP=50

# Twilio SMS (fallback when WhatsApp is not reachable).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Dashboard V2 (Sprint 5 — LeadDetailView /leads/:id).
# Backend flag kept for parity with VITE_ prefix in render.yaml.
DASHBOARD_V2_ENABLED=false
VITE_DASHBOARD_V2_ENABLED=false

# ===== LYRA — Autonomous B2B Content Engine =====
# Buffer API (publishes to LinkedIn via Buffer)
# Get token: https://buffer.com/developers/apps → Create App → Access Token
# Get profile ID: node lyra-engine/index.js --setup
BUFFER_ACCESS_TOKEN=your_buffer_access_token
BUFFER_PROFILE_ID=your_buffer_linkedin_profile_id
